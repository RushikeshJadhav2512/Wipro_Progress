{
  "name": "taskflow-pro",
  "version": "1.0.0",
  "description": "TaskFlowPro - Professional TypeScript Task Management SPA",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node src/main.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/main.js",
    "clean": "rimraf dist",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "keywords": [
    "typescript",
    "task-management",
    "spa",
    "productivity"
  ],
  "author": "TaskFlow Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
